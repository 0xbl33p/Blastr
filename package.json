    "ethers": "^6.13.4",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "qrcode": "^1.5.4",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"

# ──────────────────────────────────────────────────────────────────────
# blastr — environment template
#
# Copy to `.env` for local dev. In production (Railway), set these in the
# service Variables tab. Never commit a real `.env`.
# ──────────────────────────────────────────────────────────────────────

# ── required ──────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
BOT_TOKEN=

# 32-byte AES-256 key for encrypting wallet private keys at rest.
# Generate with:  openssl rand -base64 32
# IMPORTANT: changing this after wallets are stored makes them
# unrecoverable. Treat as a permanent secret per-environment.
WALLET_ENCRYPTION_KEY=

# Postgres connection string. Railway's Postgres plugin sets DATABASE_URL
# automatically; locally you can run a postgres container and point here.
DATABASE_URL=postgres://user:pass@localhost:5432/blastr

# Redis connection string. Railway's Redis plugin sets REDIS_URL
# automatically. Used for Telegraf session storage.
REDIS_URL=redis://localhost:6379

# ── webhook (production) ─────────────────────────────────────────────

# Public HTTPS domain Telegram will POST updates to. On Railway this is
# typically `${RAILWAY_PUBLIC_DOMAIN}` (no protocol, no trailing slash).
# If unset, the bot falls back to long-polling (dev only).
WEBHOOK_DOMAIN=

# Random opaque string Telegram includes in the X-Telegram-Bot-Api-Secret-Token
# header on every webhook POST. Generate with:  openssl rand -hex 32
WEBHOOK_SECRET=

# HTTP port the bot listens on. Railway injects PORT automatically.
PORT=3000

# ── printr ────────────────────────────────────────────────────────────

# Optional override; defaults to the public AI-integration JWT in code.
PRINTR_API_KEY=
PRINTR_API_BASE_URL=https://api-preview.printr.money

# ── optional ──────────────────────────────────────────────────────────

# OpenRouter API key for AI-generated token images
OPENROUTER_API_KEY=

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── blastr service fee (per token launch) ────────────────────────────

# Flat SOL fee sent to BLASTR_FEE_RECIPIENT_SVM on Solana launches.
# Set to 0 to disable. Recipient must be set for the fee to be charged.
BLASTR_FEE_SOL=0.05
BLASTR_FEE_RECIPIENT_SVM=

# Flat native-token fee (in wei) sent to BLASTR_FEE_RECIPIENT_EVM on EVM
# launches. Applied once per launch on the home chain. Set to 0 to disable.
BLASTR_FEE_WEI=0
BLASTR_FEE_RECIPIENT_EVM=

# ── public launch feed (optional) ──────────────────────────────────────

# Telegram channel where every successful launch is posted anonymously
# (token name, symbol, chain(s), image, Printr link — no user identifiers).
# Either "@channelusername" or numeric "-100..." chat id. Bot must be admin
# in the channel with "Post Messages" permission. Leave blank to disable.
LAUNCH_FEED_CHANNEL_ID=
